  "categories": [
    {
      "id": "cat-gaming-highfps",
      "title": "電競高幀率主機",
      "summary": "針對 FPS 與 2K/4K 高更新率遊戲，優先確保幀率穩定與低延遲體感。",
      "primaryCategory": "遊戲主機",
      "secondaryCategory": "高幀率",
      "tags": [
        "FPS",
        "2K 高刷",
        "低延遲",
        "電競"
      ],
      "points": [
        "幀率穩定性",
        "溫控與噪音平衡",
        "可升級顯卡路線"
      ],
      "detailIntro": "這個分類的核心是讓你在高幀率場景保持穩定輸出，不只是短時間跑分，還包含散熱曲線與供電餘裕。",
      "detailHeroImage": "/images/carousel/IMG_6486.JPG",
      "detailRecommendations": [
        "先定義主要遊戲與目標解析度，再反推 CPU/GPU 配比。",
        "顯卡升級時同步檢查電供與機殼風道，避免瓶頸轉移。",
        "預留至少一級升級空間，降低未來整機重換機率。"
      ],
      "detailFaqs": [
        {
          "question": "只升級顯示卡就能提升很多嗎？",
          "answer": "通常可以，但仍要確認 CPU、電供與散熱是否同步跟上。"
        },
        {
          "question": "高幀率主機會很吵嗎？",
          "answer": "可透過風扇曲線與機殼風道調整，在效能與噪音間取得平衡。"
        }
      ],
      "createdAt": "2026-02-24T06:04:50.014Z",
      "updatedAt": "2026-02-24T06:04:50.014Z"
    },
    {
      "id": "cat-creator-ai",
      "title": "創作與 AI 工作站",
      "summary": "面向剪輯、建模、AI 生成與多工流程，重視長時間輸出穩定性。",
      "primaryCategory": "創作者主機",
      "secondaryCategory": "AI 與剪輯",
      "tags": [
        "剪輯",
        "建模",
        "AI 生成",
        "多工"
      ],
      "points": [
        "長時輸出穩定",
        "儲存分層規劃",
        "記憶體與顯存配置"
      ],
      "detailIntro": "這類配置會先依軟體工作流拆解瓶頸，像是時間軸即時預覽、批次輸出與模型推理，再安排硬體權重。",
      "detailHeroImage": "/images/carousel/IMG_6158.JPG",
      "detailRecommendations": [
        "先確認主要軟體與素材格式，避免硬體方向錯配。",
        "系統碟、素材碟、專案快取建議分開配置。",
        "需長時間渲染時，散熱與電供穩定度優先於外觀。"
      ],
      "detailFaqs": [
        {
          "question": "創作主機一定要上到最頂規嗎？",
          "answer": "不一定，通常依素材規模與交件時程分級就能達到最佳成本效益。"
        },
        {
          "question": "AI 生成與剪輯可以同一台兼顧嗎？",
          "answer": "可以，會依你使用比例平衡 CPU、GPU、記憶體與儲存策略。"
        }
      ],
      "createdAt": "2026-02-24T06:04:50.014Z",
      "updatedAt": "2026-02-24T06:04:50.014Z"
    },
    {
      "id": "cat-white-theme",
      "title": "白色主題與展示機",
      "summary": "以外觀一致性、整線和燈效同步為核心，同時兼顧風道效率。",
      "primaryCategory": "主題機殼",
      "secondaryCategory": "白色主題",
      "tags": [
        "白色桌搭",
        "ARGB",
        "玻璃側透",
        "整線"
      ],
      "points": [
        "外觀一致性",
        "線材與燈效管理",
        "散熱與美觀平衡"
      ],
      "detailIntro": "主題機不是只看外觀，會把視覺完成度、散熱效率與日後維護一起納入設計。",
      "detailHeroImage": "/images/carousel/IMG_4722.JPG",
      "detailRecommendations": [
        "先定義桌面風格與色系，再選機殼與風扇。",
        "燈效控制平台盡量統一，後續維護最省事。",
        "外觀件優先確保相容性，避免後期返工。"
      ],
      "detailFaqs": [
        {
          "question": "白色主題會不會比較容易超預算？",
          "answer": "通常會有些價差，但可用替代方案控制總價。"
        },
        {
          "question": "玻璃側透會影響散熱嗎？",
          "answer": "只要風道規劃正確，外觀與散熱可以同時兼顧。"
        }
      ],
      "createdAt": "2026-02-24T06:04:50.014Z",
      "updatedAt": "2026-02-24T06:04:50.014Z"
    },
    {
      "id": "cat-business-batch",
      "title": "企業與工作室批量建置",
      "summary": "同規格批次部署與驗收，強調維運文件化與後續升級一致性。",
      "primaryCategory": "商用部署",
      "secondaryCategory": "批量採購",
      "tags": [
        "批量部署",
        "維運",
        "標準化",
        "驗收流程"
      ],
      "points": [
        "同規格一致",
        "資產標籤與文件",
        "分批交機規劃"
      ],
      "detailIntro": "批量案重點不是單台極限效能，而是規格一致、可追蹤維修與穩定交期，降低整體管理成本。",
      "detailHeroImage": "/images/carousel/IMG_7011.JPG",
      "detailRecommendations": [
        "先依部門用途做機型分級，再定義標準規格。",
        "建立資產編號與零件清單，後續維護更快。",
        "建議保留少量備援機，降低突發停機風險。"
      ],
      "detailFaqs": [
        {
          "question": "可以分批交機並先上線急件嗎？",
          "answer": "可以，通常會先安排優先部門上線。"
        },
        {
          "question": "後續升級可以維持一致規格嗎？",
          "answer": "可以，在初期就規劃升級路徑可維持管理一致性。"
        }
      ],
      "createdAt": "2026-02-24T06:04:50.014Z",
      "updatedAt": "2026-02-24T06:04:50.014Z"
    }
